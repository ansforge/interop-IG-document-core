         fhir:reference [ fhir:v "StructureDefinition/fr-cda-dispositif-medical" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Dispositif medical" ] ;
       fhir:description [ fhir:v "Entrée FR-Dispositif-medical: <ul>\n      <li>\n         <p>L'entrée Dispositif Médical est une entrée de type 'supply' qui permet de fournir les information sur un dispositif médical. </p>\n      </li>\n   </ul>" ] ;
