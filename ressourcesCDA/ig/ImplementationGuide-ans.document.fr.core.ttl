       ] ;
       fhir:name [ fhir:v "CDA - FR Quantite de produit" ] ;
       fhir:description [ fhir:v "Entrée FR-Quantite-de-produit: <p>IHE-PRE - Amount of units of the consumable</p>\n   <ul>\n      <li>\n         <p>Cette entrée permet de décrire la quantité de produit (&lt;consumable&gt;).</p>\n      </li>\n   </ul>" ] ;
