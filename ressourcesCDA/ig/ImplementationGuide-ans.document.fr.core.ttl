       ] ;
       fhir:name [ fhir:v "CDA - FR Rang de la vaccination" ] ;
       fhir:description [ fhir:v "Entrée FR-Rang-de-la-vaccination: <p>CDA -  Medication series number observation</p>\n   <ul>\n      <li>\n         <p>Cette entrée permet de préciser le rang de la vaccination dans une série d'injections vaccinantes. </p>\n      </li>\n   </ul>" ] ;
