       fhir:description [ fhir:v "Entrée FR-Modalite-sortie: <ul>\n      <li>\n         <p>Cette entrée permet de préciser la modalité de sortie du patient d'un ES (retour à domicile, EHPAD, HAD, etc...).</p>\n      </li>\n   </ul>" ] ;
