       ] ;
       fhir:name [ fhir:v "CDA - FR Instruction au patient" ] ;
       fhir:description [ fhir:v "Entrée FR-Instruction-au-patient: <p>IHE-PCC - Simple-Observation</p>\n   <ul>\n      <li>\n         <p>Cette entrée permet d’enregistrer une instruction au patient sous forme codée (c’est notamment le cas pour les prescriptions d’examens de biologie médicale). </p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
