       fhir:description [ fhir:v "Entrée FR-Historique-de-la-grossesse: <p>IHE-PCC - Pregnancy History Organizer </p>\n   <p>Cette entrée permet de regrouper les observations relatives à un épisode de grossesse.</p>" ] ;
