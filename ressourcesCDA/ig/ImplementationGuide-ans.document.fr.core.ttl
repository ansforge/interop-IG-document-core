         fhir:reference [ fhir:v "StructureDefinition/fr-cda-identification-micro-organismes-multiresistants" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Identification micro organismes multiresistants" ] ;
       fhir:description [ fhir:v "Entrée FR-Identification-micro-organismes-multiresistants: <ul>\n      <li>\n         <p>Cette entrée permet de décrire sous forme textuelle les micro-organismes identifiés. </p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
