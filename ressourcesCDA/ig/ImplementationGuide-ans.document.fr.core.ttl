         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-dicom-exposition-patient> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-dicom-exposition-patient" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR DICOM Exposition patient" ] ;
       fhir:description [ fhir:v "Entrée FR-DICOM-Exposition-patient: <p>DICOM Part 20 - inclue dans l'entrée FR-DICOM-Exposition-aux-radiations </p>\n   <ul>\n      <li>\n         <p>Cette entrée permet d’enregistrer l'identité du professionnel de santé ayant donné l'autorisation de l'exposition du patient aux rayonnements.</p>\n      </li>\n      <li>\n         <p>Elle est obligatoire dans la norme DICOM Part 20. </p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
