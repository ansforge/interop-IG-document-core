         fhir:reference [ fhir:v "StructureDefinition/fr-cda-instructions-au-dispensateur" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Instructions au dispensateur" ] ;
       fhir:description [ fhir:v "Entrée FR-Instructions-au-dispensateur: <p>IHE-PCC - Medication Fulfillment Instructions</p>\n   <ul>\n      <li>\n         <p>Toute prescription peut faire l'objet d'instructions au dispensateur (pharmacien), par exemple pour indiquer que le traitement doit être étiqueté dans une langue étrangère, etc … </p>\n      </li>\n      <li>\n         <p> Cette entrée est incluse dans une entrée Prescription à l'aide d'un élément &lt;entryRelationship&gt;. </p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
