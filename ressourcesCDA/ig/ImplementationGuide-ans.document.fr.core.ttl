       ] ;
       fhir:name [ fhir:v "CDA - FR Item plan traitement" ] ;
       fhir:description [ fhir:v "Entrée FR-Item-plan-traitement: <p>IHE-MTP Medication Treatment Plan Item</p>\n   <p>Cette entrée permet de fournir une copie du plan de traitement médicamenteux. </p>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
