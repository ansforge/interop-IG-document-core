       ] ;
       fhir:name [ fhir:v "CDA - FR Transport du patient" ] ;
       fhir:description [ fhir:v "Entrée FR-Transport-du-patient: <p>IHE-PCC - Transport</p>\n   <p>Cette entrée de type act permet de décrire le transport d'un patient/usager lors d'un déplacement (entrée ou sortie d'hôpital, ...)</p>" ] ;
