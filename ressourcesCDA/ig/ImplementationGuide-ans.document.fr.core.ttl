       ] ;
       fhir:name [ fhir:v "CDA - FR Organisme assurance maladie" ] ;
       fhir:description [ fhir:v "Entrée FR-Organisme-assurance-maladie: <p>IHE-PCC - Payers-entry <br/>\n   </p>\n   <ul>\n      <li>\n         <p>L'entrée Organisme d'assurance maladie est une entrée permettant de décrire un organisme d'assurance maladie.</p>\n      </li>\n   </ul>" ] ;
