       fhir:description [ fhir:v "Entrée FR-Reference-item-prescription: <p>IHE-PRE - Reference-Prescription-Item</p>\n   <ul>\n      <li>\n         <p>Cette entrée permet d’enregistrer la référence à un item de prescription.</p>\n      </li>\n   </ul>" ] ;
