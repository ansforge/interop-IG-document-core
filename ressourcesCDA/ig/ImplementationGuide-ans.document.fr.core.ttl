           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-administration-de-derives-du-sang> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-administration-de-derives-du-sang" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Administration de derives du sang" ] ;
       fhir:description [ fhir:v "Entrée FR-Administration-de-derives-du-sang: <p>IHE-PCC - Simple-Observation </p>\n   <ul>\n      <li>\n         <p>Cette entrée permet d'indiquer s'il y a eu ou pas une administration de dérivés du sang.</p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-allergie-ou-hypersensibilite> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-allergie-ou-hypersensibilite" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Allergie ou hypersensibilite" ] ;
       fhir:description [ fhir:v "Entrée FR-Allergie-ou-hypersensibilite: <p>IHE-PCC Allergy-And-Intolerance </p>\n   <p>Cette entrée permet de décrire une allergie ou une hypersensibilité non allergique ou une intolérance ou une idiosyncrasie, en précisant :</p>\n   <ul>\n      <li>\n         <p>Le type : allergie médicamenteuse, hypersensibilité non allergique alimentaire, etc.</p>\n      </li>\n      <li>\n         <p>La date de début et de fin</p>\n      </li>\n      <li>\n         <p>L'agent responsable : médicament, agent environnemental, …</p>\n      </li>\n      <li>\n         <p>Le statut clinique : Actif, Inactif, Résolu</p>\n      </li>\n      <li>\n         <p>La criticité : Bas, Elevé, Impossible à évaluer</p>\n      </li>\n      <li>\n         <p>La certitude : Confirmé, Non confirmé, Réfuté</p>\n      </li>\n      <li>\n         <p>La (les) réaction(s) observée(s) : urticaire, nausée, … et</p>\n      </li>\n      <li>\n         <p>La sévérité de la réaction : Potentiellement mortel, Elevé, Modéré, Bas, …</p>\n      </li>\n      <li>\n         <p>un commentaire sur la réaction</p>\n      </li>\n      <li>\n         <p>Cette entrée est basée sur l'entrée Problème (1.3.6.1.4.1.19376.1.5.3.1.4.5) qu'elle spécialise. </p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-antecedent-familial-observe> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-antecedent-familial-observe" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Antecedent familial observe" ] ;
       fhir:description [ fhir:v "Entrée FR-Antecedent-familial-observe: <p>IHE-PCC - Family History Observation </p>\n   <ul>\n      <li>\n         <p>L'entrée Antécédent familial observé permet d'apporter des informations complémentaires relatives aux membres de la famille du patient (pathologies, etc…). </p>\n      </li>\n      <li>\n         <p>Cette entrée est utilisée dans un élément Antécédents familiaux (1.3.6.1.4.1.19376.1.5.3.1.4.15). </p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
