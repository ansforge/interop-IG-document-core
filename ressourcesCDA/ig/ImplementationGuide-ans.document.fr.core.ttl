       ] ;
       fhir:name [ fhir:v "CDA - FR Hors AMM" ] ;
       fhir:description [ fhir:v "Entrée FR-Hors-AMM: <p>IHE-PCC - Simple-Observation</p>\n   <p>Cette observation permet d'indiquer si le traitement auquel elle est associée est hors AMM.</p>" ] ;
