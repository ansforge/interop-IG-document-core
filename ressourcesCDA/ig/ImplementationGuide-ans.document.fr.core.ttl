         fhir:reference [ fhir:v "StructureDefinition/fr-cda-acte-substitution" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Acte substitution" ] ;
       fhir:description [ fhir:v "Entrée FR-Acte-substitution: <p>IHE PHARM DIS - Substitution act</p>\n   <ul>\n      <li>\n         <p>Cette observation permet d'indiquer si le traitement a été substitué. </p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
