         fhir:reference [ fhir:v "StructureDefinition/fr-cda-transfusion-de-produits-sanguins" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Transfusion de produits sanguins" ] ;
       fhir:description [ fhir:v "Entrée FR-Transfusion-de-produits-sanguins: <p>Cette entrée permet d'indiquer s'il a eu ou pas transfusion de produit sanguin.</p>" ] ;
