         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-autorisation-substitution> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-autorisation-substitution" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Autorisation Substitution" ] ;
       fhir:description [ fhir:v "Entrée FR-Autorisation-Substitution: <p>IHE-PRE - Substitution-Permission</p>\n   <ul>\n      <li>\n         <p>Cette observation permet d'indiquer si le traitement auquel elle est associée peut être substitué.</p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-certitude> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-certitude" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Certitude" ] ;
       fhir:description [ fhir:v "Entrée FR-Certitude: <p>Cette entrée permet de fournir la certitude d'une observation (problème ou allergie/hypersensibilité). </p>\n   <ul>\n      <li>\n         <p>Elle est utilisée exclusivement dans un lien entryRelationship grâce auquel elle est liée à l’élément qu’elle qualifie. </p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-commentaire-er> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-commentaire-er" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Commentaire ER" ] ;
       fhir:description [ fhir:v "Entrée FR-Commentaire-ER: <p>IHE-PCC - Comments <br/>\n   </p>\n   <p>L’entrée FR-Commentaire-ER est un élément qui permet de joindre un commentaire à une entrée ou à une section. </p>\n   <ul>\n      <li>\n         <p> Note : IHE PCC a limité l’utilisation de l’élément « Comments » (1.3.6.1.4.1.19376.1.5.3.1.4.2) aux entrées de type observation et organizer. </p>\n      </li>\n      <li>\n         <p>Ce n’est pas le cas dans CDD pour l’élément « Comment » (2.16.840.1.113883.10.20.1.40).</p>\n      </li>\n      <li>\n         <p> Dans le CI-SIS, le choix a été fait de ne pas limiter l’utilisation de l’entrée FR-Commentaire-ER (1.3.6.1.4.1.19376.1.5.3.1.4.2) comme dans CCD. </p>\n      </li>\n      <li>\n         <p>Lorsque l’entrée FR-Commentaire-ER est utilisée dans une entrée : </p>\n         <ul>\n            <li>\n               <p>de type organizer : l’utiliser dans un élément component avec l’attribut type-Code='COMP'.</p>\n            </li>\n            <li>\n               <p>de type observation ou act, etc… : l’utiliser dans un élément entryRelationship avec les attributs typeCode='SUBJ' et inversionInd='true'. </p>\n            </li>\n         </ul>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-criticite> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-criticite" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Criticite" ] ;
       fhir:description [ fhir:v "Entrée FR-Criticite: <ul>\n      <li>\n         <p>Cette entrée permet de fournir la criticité d'une l’allergie ou hypersensibilité.</p>\n      </li>\n      <li>\n         <p>Elle est utilisée exclusivement dans un lien entryRelationship grâce auquel elle est liée à l’élément qu’elle qualifie. </p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-demande-d-examen-ou-de-suivi> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-demande-d-examen-ou-de-suivi" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Demande d examen ou de suivi" ] ;
       fhir:description [ fhir:v "Entrée FR-Demande-d-examen-ou-de-suivi: <p>IHE-PCC - Observation Request </p>\n   <ul>\n      <li>\n         <p>L'entrée Demande d'examen / de suivi est une observation qui permet de porter des demandes d'examens (analyses biologiques, évaluations, étude d'imagerie, etc…) ou de suivis particuliers à programmer dans le cadre d'un plan de soins. </p>\n      </li>\n      <li>\n         <p>Cette entrée est basée sur l'élément Simple Observation (1.3.6.1.4.1.19376.1.5.3.1.4.13) qu'elle spécialise.</p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-dicom-administration-produit-de-sante> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-dicom-administration-produit-de-sante" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR DICOM Administration produit de sante" ] ;
       fhir:description [ fhir:v "Entrée FR-DICOM-Administration-produit-de-sante: <p>DICOM Part 20 - Procedural Medication</p>\n   <p>Cette entrée permet d'enregistrer l’administration de produits (hors radiopharmaceutiques) :</p>\n   <ul>\n      <li>\n         <p>produit administré</p>\n      </li>\n      <li>\n         <p>dose administrée</p>\n      </li>\n      <li>\n         <p>voie d’administration</p>\n      </li>\n      <li>\n         <p>numéro de lot</p>\n      </li>\n      <li>\n         <p>autres informations liées à l’administration d’un produit </p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
