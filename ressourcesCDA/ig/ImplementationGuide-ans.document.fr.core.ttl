       ] ;
       fhir:name [ fhir:v "CDA - FR Transport du professionnel" ] ;
       fhir:description [ fhir:v "Entrée FR-Transport-du-professionnel: <p>Cette entrée de type act permet de décrire le transport d'un professionnel lors d’un déplacement. </p>" ] ;
