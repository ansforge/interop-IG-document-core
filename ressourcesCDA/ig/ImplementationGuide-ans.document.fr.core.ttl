       ] ;
       fhir:name [ fhir:v "CDA - FR Habitus Mode de vie" ] ;
       fhir:description [ fhir:v "Entrée FR-Habitus-Mode-de-vie: <p>IHE-PCC - Social History Observation</p>\n   <ul>\n      <li>\n         <p>L'entrée Habitus, Mode de vie permet de décrire des éléments sociaux du patient. </p>\n      </li>\n      <li>\n         <p>Cette entrée est basée sur l'élément Simple Observation (1.3.6.1.4.1.19376.1.5.3.1.4.13) qu'elle spécialise en portant des contraintes sur les vocabulaires des éléments &lt;code&gt; et &lt;value&gt;. </p>\n      </li>\n   </ul>" ] ;
