       fhir:description [ fhir:v "Entrée FR-Synthese-medicale-sejour: <ul>\n      <li>\n         <p>Cette entrée permet de fournir, sous forme textuelle, une synthèse médicale du séjour. </p>\n      </li>\n   </ul>" ] ;
