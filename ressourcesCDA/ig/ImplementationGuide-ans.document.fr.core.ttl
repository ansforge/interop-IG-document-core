         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-liste-des-problemes> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-liste-des-problemes" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Liste des problemes" ] ;
       fhir:description [ fhir:v "Entrée FR-Liste-des-problemes: <p>IHE-PCC - Problem-Concern</p>\n   <ul>\n      <li>\n         <p>Cette entrée permet de regrouper des informations relatives aux pathologies non-allergiques du patient. Elle regroupe des entrées FR-Probleme qui décrivent chacun une pathologie.</p>\n      </li>\n   </ul>" ] ;
