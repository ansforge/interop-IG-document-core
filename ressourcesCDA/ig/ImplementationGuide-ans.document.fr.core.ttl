       ] ;
       fhir:name [ fhir:v "CDA - FR Reference item plan traitement" ] ;
       fhir:description [ fhir:v "Entrée FR-Reference-item-plan-traitement: <p>IHE-Pharm - </p>\n   <ul>\n      <li>\n         <p>Cette entrée permet d’enregistrer une référence à un traitement dans un plan de traitement.</p>\n      </li>\n   </ul>" ] ;
