       fhir:description [ fhir:v "Entrée FR-Rencontre: <p>IHE-PCC - Encounter</p>\n   <p> L'entrée 'Rencontre' est un élément de type 'encounter' permettant de conserver les modalités d'une rencontre du patient. Il peut s'agir d'une rencontre passée ou à venir. </p>" ] ;
