           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-dicom-observation-subordonnee> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-dicom-observation-subordonnee" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR DICOM Observation subordonnee" ] ;
       fhir:description [ fhir:v "Entrée FR-DICOM-Observation-subordonnee: DICOM PART 20 - Observation codée" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-dicom-quantite> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-dicom-quantite" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR DICOM Quantite" ] ;
       fhir:description [ fhir:v "Entrée FR-DICOM-Quantite: <p>DICOM Part 20 - Quantity Measurement</p>\n   <p>Cette entrée permet d’enregistrer les mesures quantitatives telles que les mesures linéaires, les mesures de surface, de volume et numériques en précisant :</p>\n   <ul>\n      <li>\n         <p>Le type de la mesure,</p>\n      </li>\n      <li>\n         <p>La localisation anatomique / latéralité / topographie, </p>\n      </li>\n      <li>\n         <p>La quantité</p>\n         <p>Si la mesure quantitative est basée sur les données d’une image, une référence à l’image peut être précisée dans la partie narrative. </p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-dicom-quantite-subordonnee> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-dicom-quantite-subordonnee" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR DICOM Quantite subordonnee" ] ;
       fhir:description [ fhir:v "Entrée FR-DICOM-Quantite-subordonnee: <p>Cette entrée permet d’enregistrer les mesures quantitatives telles que les mesures linéaires, les mesures de surface, de volume et numériques en précisant : </p>\n   <ul>\n      <li>\n         <p> Le type de la mesure,  </p>\n      </li>\n      <li>\n         <p> La localisation anatomique / latéralité / topographie,  </p>\n      </li>\n      <li>\n         <p> La quantité </p>\n      </li>\n   </ul>\n   <p>Si la mesure quantitative est basée sur les données d’une image, une référence à l’image peut être précisée dans la partie narrative. </p>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
