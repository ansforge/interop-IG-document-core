       fhir:description [ fhir:v "Entrée FR-Observation-sur-la-grossesse: <p>IHE-PCC - Pregnancy Observation</p>\n   <ul>\n      <li>\n         <p>Cette entrée permet d'apporter des informations relatives aux grossesses actuelle ou passées. </p>\n      </li>\n   </ul>" ] ;
