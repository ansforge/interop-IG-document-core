       ] ;
       fhir:name [ fhir:v "CDA - FR Periode de renouvellement" ] ;
       fhir:description [ fhir:v "Entrée FR-Periode-de-renouvellement: <p>IHE-PRE - Renewal Period</p>\n   <ul>\n      <li>\n         <p>Cette observation permet d'indiquer la période de renouvellement.</p>\n      </li>\n   </ul>" ] ;
