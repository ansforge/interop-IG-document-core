       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-prelevement> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-prelevement" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Prelevement" ] ;
       fhir:description [ fhir:v "Entrée FR-Prelevement: <p>IHE-PCC - Specimen collection</p>\n   <ul>\n      <li>\n         <p>L'élément 'Prélèvement' est un élément de type 'procedure' qui permet de décrire le prélèvement et l'échantillon biologique (le matériel).</p>\n      </li>\n   </ul>\n   <ul>\n      <li>\n         <p>Cet élément est obligatoirement inclus dans une entrée 'Résultats d'examens de biologie médicale' (Laboratory Report Data Processing Entry – 1.3.6.1.4.1.19376.1.3.1). </p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-prescription> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-prescription" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Prescription" ] ;
       fhir:description [ fhir:v "Entrée FR-Prescription: <p>IHE-PCC - Supply</p>\n   <p>Cette entrée permet de décrire l’acte de prescription lié à un élément substanceAdministration par l’intermédiaire d’un élément entryRelationship dans les entrées suivantes : </p>\n   <ul>\n      <li>\n         <p>FR-Traitement</p>\n      </li>\n      <li>\n         <p>FR-Traitement-maladie-rare</p>\n      </li>\n      <li>\n         <p>FR-Vaccination</p>\n      </li>\n      <li>\n         <p>FR-Vaccin-recommande</p>\n      </li>\n      <li>\n         <p>FR-Fluide-intraveineux<strong/>\n         </p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-probleme> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-probleme" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Probleme" ] ;
       fhir:description [ fhir:v "Entrée FR-Probleme: <p>IHE-PCC - Problem-Entry</p>\n   <p>Cette entrée permet de décrire un problème du patient (une pathologie par exemple) en précisant : <br/> Le type de problème observé : problème, plainte, symptôme, diagnostic, etc.</p>\n   <ul>\n      <li>\n         <p>Le problème observé (en général, la pathologie observée)</p>\n      </li>\n      <li>\n         <p>La sévérité</p>\n      </li>\n      <li>\n         <p>Le statut du problème (sauf pour une réaction à une allergie/hypersensibilité)</p>\n      </li>\n      <li>\n         <p>Le statut clinique du patient (sauf pour une réaction à une allergie/hypersensibilité)</p>\n      </li>\n      <li>\n         <p>Un commentaire. </p>\n      </li>\n   </ul>" ] ;
