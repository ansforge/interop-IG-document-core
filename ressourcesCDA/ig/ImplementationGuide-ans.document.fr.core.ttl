       fhir:description [ fhir:v "Entrée FR-Observation-sur-echelle-douleur: <p>IHE-PCC - Pain Score Observation</p>\n   <ul>\n      <li>\n         <p>Cette entrée permet d'enregistrer l'évaluation du patient de sa douleur sur une échelle de 1 à 10.</p>\n      </li>\n   </ul>" ] ;
