       ] ;
       fhir:name [ fhir:v "CDA - FR Evenement" ] ;
       fhir:description [ fhir:v "Entrée FR-Evenement: <p>FR-Evenement</p>\n   <p>Cette entrée est un élément de type 'encounter' permettant de conserver les données d’activités liées à un patient / usager. Il peut s'agir d'un évènement passé ou à venir.</p>" ] ;
