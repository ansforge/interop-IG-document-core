           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://interop.esante.gouv.fr/ig/document/core/StructureDefinition/fr-cda-dicom-administration-radiopharmaceutique> ;
         fhir:reference [ fhir:v "StructureDefinition/fr-cda-dicom-administration-radiopharmaceutique" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR DICOM Administration radiopharmaceutique" ] ;
       fhir:description [ fhir:v "Entrée FR-DICOM-Administration-radiopharmaceutique: <p>Cette entrée permet d'enregistrer l’administration de produits radiopharmaceutiques :</p>\n   <ul>\n      <li>\n         <p>produit administré</p>\n      </li>\n      <li>\n         <p>dose administrée</p>\n      </li>\n      <li>\n         <p>voie d’administration</p>\n      </li>\n      <li>\n         <p>numéro de lot</p>\n      </li>\n      <li>\n         <p>autres informations liées à l’administration d’un produit </p>\n      </li>\n   </ul>" ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ] ;
       fhir:groupingId [ fhir:v "Ressources CDA corps" ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
