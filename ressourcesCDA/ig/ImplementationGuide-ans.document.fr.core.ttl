         fhir:reference [ fhir:v "StructureDefinition/fr-cda-type-document-attache" ]
       ] ;
       fhir:name [ fhir:v "CDA - FR Type document attache" ] ;
       fhir:description [ fhir:v "Entrée FR-Type-document-attache: <p>Élément de type Simple Observations (1.3.6.1.4.1.19376.1.5.3.1.4.13) définissant le type de document attaché.</p>" ] ;
