       fhir:path [ fhir:v "Encounter.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "2.16.840.1.113883.10.20.1.21"
       ]
     ] [
       fhir:id [ fhir:v "Encounter.templateId:ccdPlanOfCareActivityPlannedRealised" ] ;
       fhir:path [ fhir:v "Encounter.templateId" ] ;
       fhir:sliceName [ fhir:v "ccdPlanOfCareActivityPlannedRealised" ] ;
       fhir:short [ fhir:v "Conformité Plan of care activity (CCD) Si rencontre planifiée (moodCode='PMRS') ou prévue non confirmée  (moodCode='ARQ')" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "Encounter.templateId:ccdPlanOfCareActivityPlannedRealised.root" ] ;
       fhir:path [ fhir:v "Encounter.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "2.16.840.1.113883.10.20.1.25"
       ]
     ] [
       fhir:id [ fhir:v "Encounter.templateId:frRencontre" ] ;
       fhir:path [ fhir:v "Encounter.templateId" ] ;
       fhir:sliceName [ fhir:v "frRencontre" ] ;
       fhir:short [ fhir:v "Conformité FR-Rencontre (CI-SIS)" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "Encounter.templateId:frRencontre.root" ] ;
       fhir:path [ fhir:v "Encounter.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "1.2.250.1.213.1.1.3.58"
       ]
     ] [
       fhir:id [ fhir:v "Encounter.classCode" ] ;
       fhir:path [ fhir:v "Encounter.classCode" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Encounter.moodCode" ] ;
       fhir:path [ fhir:v "Encounter.moodCode" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Encounter.id" ] ;
       fhir:path [ fhir:v "Encounter.id" ] ;
       fhir:short [ fhir:v "Identifiant" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ]
     ] [
       fhir:id [ fhir:v "Encounter.code" ] ;
       fhir:path [ fhir:v "Encounter.code" ] ;
       fhir:short [ fhir:v "<span style='font-weight: bold;'>Type de rencontre</span>\n   <br clear='none'/> Valeur généralement issue du JDV_HL7_ActEncounterCode_CISIS (2.16.840.1.113883.1.11.13955) mais un autre JDV peut être utilisé pour certains documents spécifiques (dans ce cas, le JDV est fourni dans le volet concerné). <br clear='none'/>" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Encounter.text" ] ;
       fhir:path [ fhir:v "Encounter.text" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Encounter.text.xmlText" ] ;
       fhir:path [ fhir:v "Encounter.text.xmlText" ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "Description narrative"
       ]
     ] [
       fhir:id [ fhir:v "Encounter.effectiveTime" ] ;
       fhir:path [ fhir:v "Encounter.effectiveTime" ] ;
       fhir:short [ fhir:v "Date de la rencontre Si la rencontre est réalisée (EVN) ou planifiée (PMRS) : la date est obligatoire.  Si la rencontre est prévue non confirmée (ARQ) : la date est facultative." ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Encounter.priorityCode" ] ;
       fhir:path [ fhir:v "Encounter.priorityCode" ] ;
       fhir:short [ fhir:v "<b>Confirmation attendue</b>\n   <br clear='none'/> Si la rencontre est prévue non confirmée (ARQ) et qu'une confirmation est attendue : <br clear='none'/>\n   <ul>\n      <li>code='CS'</li>\n      <li>displayName='Recontacter pour fixer RDV'</li>\n      <li>codeSystem='<span style='line-height: 115%;'>2.16.840.1.113883.5.7</span>'</li>\n      <li>codeSystemName='<span style='line-height: 115%;'>ActPriority</span>'</li>\n   </ul> Sinon, <br clear='none'/>\n   <ul>\n      <li>l'élément &lt;priorityCode&gt; n'est pas fourni.</li>\n   </ul>" ]
     ] [
       fhir:id [ fhir:v "Encounter.participant" ] ;
       fhir:path [ fhir:v "Encounter.participant" ] ;
       fhir:short [ fhir:v "Lieu d'exécution" ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Encounter.participant.typeCode" ] ;
       fhir:path [ fhir:v "Encounter.participant.typeCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "LOC"
       ]
     ] [
       fhir:id [ fhir:v "Encounter.participant.participantRole.classCode" ] ;
       fhir:path [ fhir:v "Encounter.participant.participantRole.classCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "SDLOC"
       ]
     ] [
       fhir:id [ fhir:v "Encounter.participant.participantRole.id" ] ;
       fhir:path [ fhir:v "Encounter.participant.participantRole.id" ] ;
       fhir:short [ fhir:v "<b>Identifiant de l'établissement</b>" ]
     ] [
       fhir:id [ fhir:v "Encounter.participant.participantRole.addr" ] ;
       fhir:path [ fhir:v "Encounter.participant.participantRole.addr" ] ;
       fhir:short [ fhir:v "<b>Adresse</b>" ]
     ] [
       fhir:id [ fhir:v "Encounter.participant.participantRole.telecom" ] ;
       fhir:path [ fhir:v "Encounter.participant.participantRole.telecom" ] ;
       fhir:short [ fhir:v "<b>Coordonnées télécom</b>" ]
     ] )
  ] . # 

