       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/StructureDefinition/elementdefinition-defaulttype"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/StructureDefinition/elementdefinition-defaulttype>
