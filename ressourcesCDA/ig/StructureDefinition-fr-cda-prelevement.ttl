       fhir:id [ fhir:v "Procedure.templateId:frPrelevement" ] ;
       fhir:path [ fhir:v "Procedure.templateId" ] ;
       fhir:sliceName [ fhir:v "frPrelevement" ] ;
       fhir:short [ fhir:v "Conformité FR-Prelevement (CI-SIS)" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "Procedure.templateId:frPrelevement.root" ] ;
       fhir:path [ fhir:v "Procedure.templateId.root" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [
         a fhir:String ;
         fhir:v "1.2.250.1.213.1.1.3.77"
       ]
     ] [
       fhir:id [ fhir:v "Procedure.classCode" ] ;
       fhir:path [ fhir:v "Procedure.classCode" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.moodCode" ] ;
       fhir:path [ fhir:v "Procedure.moodCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "EVN"
       ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.code" ] ;
       fhir:path [ fhir:v "Procedure.code" ] ;
       fhir:short [ fhir:v "<b>Acte de prélèvement</b>\n   <br/>\n   <ul style=''>\n      <li style=''>Pour un prélèvement en vue d'examen de biologie médicale, le code affiné NABM de l'acte de prélèvement doit être renseigné si connu, sauf dans le cas d'un recueil d'échantillon effectué par le patient lui-même.</li>\n      <li style=''>Un prélèvement cytologique ou de tissu en vue d'un examen d'anatomie ou de cytologie pathologiques est codé à l'aide d'une nomenclature précisée dans les modèles de contenus métiers.</li>\n      <li style=''>Par défaut, utiliser le code suivant :</li>\n      <ul style=''>\n         <li>code='33882-2'</li>\n         <li>displayName='Prélèvement'</li>\n         <li>codeSystem='2.16.840.1.113883.6.1'</li>\n         <li>codeSystemName='LOINC'</li>\n      </ul>\n   </ul>" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.effectiveTime" ] ;
       fhir:path [ fhir:v "Procedure.effectiveTime" ] ;
       fhir:short [ fhir:v "Date du prélèvement La date et heure de prélèvement doit être renseignée si elle est connue. En cas d'acte ponctuel, c'est la date et heure de fin (élément high) qui horodate le prélèvement. " ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.targetSiteCode" ] ;
       fhir:path [ fhir:v "Procedure.targetSiteCode" ] ;
       fhir:short [ fhir:v "<div>\n      <strong>Localisation du prélèvement</strong>\n   </div>\n   <div>\n      <strong>SNOMED CT (</strong>\n      <strong>2.16.840.1.113883.6.96</strong>\n      <strong>)</strong>\n   </div>" ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.participant" ] ;
       fhir:path [ fhir:v "Procedure.participant" ] ;
       fhir:slicing [
         fhir:discriminator ( [
           fhir:type [ fhir:v "value" ] ;
           fhir:path [ fhir:v "typeCode" ]
         ] ) ;
         fhir:rules [ fhir:v "open" ]
       ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.participant:EchantillonPreleve" ] ;
       fhir:path [ fhir:v "Procedure.participant" ] ;
       fhir:sliceName [ fhir:v "EchantillonPreleve" ] ;
       fhir:short [ fhir:v "Échantillon prélevé" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.participant:EchantillonPreleve.typeCode" ] ;
       fhir:path [ fhir:v "Procedure.participant.typeCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "PRD"
       ]
     ] [
       fhir:id [ fhir:v "Procedure.participant:EchantillonPreleve.participantRole.classCode" ] ;
       fhir:path [ fhir:v "Procedure.participant.participantRole.classCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "SPEC"
       ]
     ] [
       fhir:id [ fhir:v "Procedure.participant:EchantillonPreleve.participantRole.id" ] ;
       fhir:path [ fhir:v "Procedure.participant.participantRole.id" ] ;
       fhir:short [ fhir:v "<b>Identifiant de l'échantillon</b>\n   <br/> L'identifiant de l'échantillon est éventuellement multiple (premier identifiant attribué par le préleveur, puis réidentification par le laboratoire). <br/> L'un des identifiants est visible sur l'échantillon matériel (par exemple en code barre sur le tube ou le bocal)." ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "Procedure.participant:DispositifUtilise" ] ;
       fhir:path [ fhir:v "Procedure.participant" ] ;
       fhir:sliceName [ fhir:v "DispositifUtilise" ] ;
       fhir:short [ fhir:v "Dispositif utilisé" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "*" ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.participant:DispositifUtilise.typeCode" ] ;
       fhir:path [ fhir:v "Procedure.participant.typeCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "DEV"
       ]
     ] [
       fhir:id [ fhir:v "Procedure.participant:DispositifUtilise.participantRole.classCode" ] ;
       fhir:path [ fhir:v "Procedure.participant.participantRole.classCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "MANU"
       ]
     ] [
       fhir:id [ fhir:v "Procedure.participant:DispositifUtilise.participantRole.playingDevice" ] ;
       fhir:path [ fhir:v "Procedure.participant.participantRole.playingDevice" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ]
     ] [
       fhir:id [ fhir:v "Procedure.participant:DispositifUtilise.participantRole.playingDevice.code" ] ;
       fhir:path [ fhir:v "Procedure.participant.participantRole.playingDevice.code" ] ;
       fhir:short [ fhir:v "<p>\n      <strong>Code du dispositif</strong>\n   </p>\n   <ul>\n      <li>\n         <p>Par exemple 'Trousse de détection HPV' <br/>\n         </p>\n      </li>\n   </ul>" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.participant:ProduitUtilise" ] ;
