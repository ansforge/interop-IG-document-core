       ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "2" ]
     ] [
       fhir:id [ fhir:v "Procedure.entryRelationship.act.templateId:iheSpecimenReceived" ] ;
       fhir:path [ fhir:v "Procedure.entryRelationship.act.templateId" ] ;
       fhir:sliceName [ fhir:v "iheSpecimenReceived" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "Procedure.entryRelationship.act.templateId:frEchantillonDateReception" ] ;
       fhir:path [ fhir:v "Procedure.entryRelationship.act.templateId" ] ;
       fhir:sliceName [ fhir:v "frEchantillonDateReception" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "Procedure.entryRelationship.act.classCode" ] ;
       fhir:path [ fhir:v "Procedure.entryRelationship.act.classCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "ACT"
       ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.entryRelationship.act.moodCode" ] ;
       fhir:path [ fhir:v "Procedure.entryRelationship.act.moodCode" ] ;
       fhir:pattern [
