       fhir:path [ fhir:v "Procedure.participant.participantRole.classCode" ] ;
       fhir:pattern [
         a fhir:Code ;
         fhir:v "ADTV"
       ]
     ] [
       fhir:id [ fhir:v "Procedure.participant:ProduitUtilise.participantRole.playingDevice" ] ;
       fhir:path [ fhir:v "Procedure.participant.participantRole.playingDevice" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ]
     ] [
       fhir:id [ fhir:v "Procedure.participant:ProduitUtilise.participantRole.playingDevice.code" ] ;
       fhir:path [ fhir:v "Procedure.participant.participantRole.playingDevice.code" ] ;
       fhir:short [ fhir:v "<p>\n      <strong>Code du produit</strong>\n   </p>\n   <ul>\n      <li>\n         <p>Par exemple 'Milieu' pour le test HPV <br/>\n         </p>\n      </li>\n   </ul>" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:mustSupport [ fhir:v true ]
     ] [
       fhir:id [ fhir:v "Procedure.entryRelationship.act" ] ;
       fhir:path [ fhir:v "Procedure.entryRelationship.act" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ]
     ] [
       fhir:id [ fhir:v "Procedure.entryRelationship.act.templateId" ] ;
       fhir:path [ fhir:v "Procedure.entryRelationship.act.templateId" ] ;
       fhir:slicing [
